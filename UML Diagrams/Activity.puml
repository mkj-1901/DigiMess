@startuml Activity_Diagram
|Student|
start
:Login (Email/Pass or Google OAuth);
:View Dashboard;

partition "Student Actions" {
    if ("Log Attendance?") then (Yes)
        :Select Meals (Breakfast/Lunch/Dinner);
        :Submit Attendance;
    else (No)
    endif

    if ("Opt-out of meals?") then (Yes)
        :Select Dates & Provide Reason;
        :Submit opt-out request;
        |Admin|
        :Review Request;
        if ("Approved?") then (Yes)
            :Mark as Approved;
        else (No)
            :Mark as Rejected;
        endif
        |Student|
    else (No)
    endif

    if ("Submit review?") then (Yes)
        :Write review and rate meal;
        :Submit review;
    else (No)
    endif

    if ("End of Month?") then (Yes)
        :Check rebate calculation;
    else (No)
    endif
}

|Admin|
partition "Admin Actions" {
    :Login to Admin Panel;
    :View System Stats & Dashboard;
    :Review pending opt-out requests;
    :Calculate & approve monthly rebates;
    :View recent attendance;
    
    if ("Generate Insights?") then (Yes)
        :Request Review Summary;
        |ML Service|
        :Run DistilBART Summarizer;
        :Run DistilBERT Sentiment Analysis;
        |Admin|
        :View AI Summary & Sentiment;
    else (No)
    endif
}

stop
@enduml